# MiniMax API 配置
MINIMAX_API_KEY=your-api-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M3

# LLM 调用超时（秒）
LLM_TIMEOUT_SEC=90

# Python 代码执行沙箱
PYTHON_EXEC_TIMEOUT_SEC=5
PYTHON_MEM_LIMIT_MB=256

# 反思机制（默认 2 轮：1 轮主流程 + 1 轮兜底；超过则不必要）
MAX_REFLECT_ROUNDS=2
REFLECT_CONFIDENCE_THRESHOLD=0.85

# CORS（前端地址）
FRONTEND_ORIGIN=http://localhost:5173